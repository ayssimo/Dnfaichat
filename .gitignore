<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>AI assistant for overcoming fear</title>

<style>

body{
font-family: Arial;
background:#cfeeff;
margin:0;
padding:20px;
}

h1{
text-align:center;
}

#chat{
background:#f5efe6;
height:400px;
overflow-y:auto;
padding:15px;
border-radius:12px;
margin-bottom:10px;
}

.user{
background:#b8f2d6;
padding:8px;
margin:8px;
border-radius:10px;
text-align:right;
}

.ai{
background:white;
padding:8px;
margin:8px;
border-radius:10px;
}

input{
width:75%;
padding:10px;
border-radius:10px;
border:none;
}

button{
padding:10px;
border-radius:10px;
border:none;
background:#7cc6ff;
cursor:pointer;
}

#results{
margin-top:20px;
background:#f5efe6;
padding:15px;
border-radius:10px;
}

</style>
</head>

<body>

<h1>AI assistant for overcoming fear</h1>

<div id="chat"></div>

<input id="input" placeholder="Write down all your thoughts... in English">
<button onclick="send()">Send</button>

<br><br>

<button onclick="showResults()">Show my results</button>

<div id="results"></div>

<script>

function send(){

let text = document.getElementById("input").value;
if(text=="") return;

let chat = document.getElementById("chat");

chat.innerHTML += "<div class='user'>"+text+"</div>";

document.getElementById("input").value="";

chat.scrollTop = chat.scrollHeight;

}

function showResults(){

document.getElementById("results").innerHTML =
"<p>Your results will appear here.</p>";

}

</script>

</body>
</html>
